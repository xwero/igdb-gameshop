#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use Symfony\Component\Console\Application;
use Xwero\IgdbGameshop\PIM\Commands\IGDBGamesCommand;
use Xwero\IgdbGameshop\PIM\Commands\IGDBCoversCommand;

$application = new Application();

$application->addCommand(new IGDBGamesCommand());
$application->addCommand(new IGDBCoversCommand());

$application->run();